# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=parlay
POSTGRES_PASSWORD=parlay
POSTGRES_DB=parlay_beater
DATABASE_URL=postgresql://parlay:parlay@postgres:5432/parlay_beater

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Football Data APIs ────────────────────────────────────────────────────────
# Get a free key at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_key_here

# Get a key at: https://www.api-football.com/
API_FOOTBALL_KEY=your_key_here

# ── App Settings ──────────────────────────────────────────────────────────────
# "development" or "production"
ENV=development

# Set to "true" to bypass real API calls during early development
USE_MOCK_DATA=true

# Default leagues to ingest (comma-separated API codes)
# PL=Premier League, PD=La Liga, SA=Serie A, BL1=Bundesliga, FL1=Ligue 1
TARGET_LEAGUES=PL,PD,SA,BL1,FL1

# Cache TTL in seconds (1 hour default)
PREDICTION_CACHE_TTL=3600

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:////data/mlflow.db
